# --- LLM Judge (usado pelo DeepEval para avaliar as respostas) ---
# Se JUDGE_BASE_URL estiver definido, usa LLM customizada (compatível com Azure OpenAI)
# Caso contrário, usa OPENAI_API_KEY padrão

JUDGE_BASE_URL=https://fusion-llm.brq.com
JUDGE_API_KEY=sua-chave-aqui
JUDGE_MODEL=gpt-5.2
JUDGE_API_VERSION=2025-03-01-preview

# Alternativa: OpenAI direto (usado se JUDGE_BASE_URL não estiver definido)
# OPENAI_API_KEY=sk-...

# Banco de dados
DATABASE_URL=sqlite:///./agenteval.db
